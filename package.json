{
  "name": "pi-arxivist",
  "version": "0.1.4",
  "description": "Fetch arxiv papers as Markdown (pi extension)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "fmt": "prettier --write \"src/**/*.ts\"",
    "fmt:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run fmt:check",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "npm run clean && npm run check && npm run build"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "arxiv",
    "latex",
    "markdown",
    "pi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luishfonseca/pi-arxivist.git"
  },
  "bugs": {
    "url": "https://github.com/luishfonseca/pi-arxivist/issues"
  },
  "homepage": "https://github.com/luishfonseca/pi-arxivist#readme",
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "pandoc-wasm": "^1.1.0",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@earendil-works/pi-coding-agent": "^0.79.4",
    "@earendil-works/pi-tui": "^0.79.4",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.21",
    "eslint": "^9.39.4",
    "prettier": "^3.8.4",
    "typebox": "^1.2.11",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  }
}
